@SEL_LOOP
WHILE 1
 VSYNC 1
 B=BUTTON(1)
 IF B AND #UP+#DOWN THEN 
  BEEP 62
  IF B AND #UP THEN DEC PART
  IF B AND #DOWN THEN INC PART
  IF PART<0 THEN PART=0
  IF PART>=CHAP_CNT[CHAP] THEN PART=CHAP_CNT[CHAP]-1
  GOSUB @SEL_INIT2
 ENDIF
 IF B AND #LEFT+#RIGHT THEN 
  BEEP 54
  IF B AND #LEFT THEN DEC CHAP
  IF B AND #RIGHT THEN INC CHAP
  IF CHAP<0 THEN 
   CHAP=0
  ELSEIF CHAP>=LEN(CHAP_CNT) THEN 
   CHAP=LEN(CHAP_CNT)-1
  ELSE
   PART=0
   GOSUB @SEL_INIT
  ENDIF
 ENDIF
