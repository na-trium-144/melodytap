 NPT=0
 '50msまえまで
 FOR I=FLOOR(FI-FI_BEGIN+(MS-LASTMS)/MSSTEP) TO CEIL(FI-FI_BEGIN+(MS-LASTMS-50)/MSSTEP) STEP -1
  IF CHKGEN(I) && GEN[I] THEN 
   NPT=GEN[I]
   GEN[I]=0
   'LASTFI=I
   'IF NPT>=BORDER THEN 
   GOTO @HT2
  ENDIF
 NEXT
