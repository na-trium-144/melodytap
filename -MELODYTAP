COMMON DEF MSG MES$
 GPAGE 0,4
 GFILL 0,464,399,511,0
 GPKNJSCALE 1,1
 X=0:Y=0:A=0
 FOR I=0 TO LEN(MES$)-1
  IF MES$[I]==CHR$(10) THEN X=0:INC Y:CONTINUE
  IF X+12>360 THEN X=0:INC Y
  GPKNJPRINT X+10,474+Y*16,MES$[I],360-X,0 OUT L,R$
  IF R$!="" THEN 
   X=0:INC Y
   GPKNJPRINT X+10,474+Y*16,MES$[I],360-X,0 OUT L,R$
  ENDIF
  INC X,L+2
  IF !A THEN BEEP 9
  FOR J=0 TO 7
   IF A THEN BREAK
   VSYNC 1
   IF BUTTON(2) AND #A THEN BEEP 9:A=1
  NEXT
 NEXT
 REPEAT
  VSYNC 1
 UNTIL BUTTON(2) AND #A
 GPAGE 0,0
END


