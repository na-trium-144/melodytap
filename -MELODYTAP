@BUTTON
 B=BUTTON(2)
 IF B AND #DOWN+#B THEN TAP=1
 IF B AND #RIGHT+#A THEN TAP=2
 IF B AND #UP+#X+#R THEN TAP=3
 IF B AND #LEFT+#Y+#L THEN TAP=4
 TOUCH OUT T,X,Y
 IF T==1 THEN 
  TAP=(FLOOR((ATAN(X-160,Y-120)+RAD(45))/RAD(90)) AND 3)+1
 ENDIF
 IF (FRAME MOD 2)==0 THEN 
  INC REPLAY$,CHR$(TAP OR 1<<6)
 ELSE 
  REPLAY$[FRAME/2]=CHR$(ASC(REPLAY$[FRAME/2]) OR TAP<<3)
 ENDIF
RETURN
@AUTO
 IF CHKGEN(FI-FI_BEGIN) THEN 
  TAP=MIN(FLOOR(GEN[FI-FI_BEGIN]*5/GMAX),4)
 ENDIF
RETURN
@REPLAY
 TAP=ASC(REPLAY$[FRAME/2])>>3*(FRAME MOD 2) AND 7
RETURN

