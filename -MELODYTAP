DEF MML_REP$(OLD$)
 VAR MML$=OLD$+"",I,J,K,N$,R$
 DIM MT$[0]
 FOR I=0 TO LEN(MML$)-1
  IF MML$[I]!="{" THEN CONTINUE
  K=0
  FOR J=I+1 TO LEN(MML$)-1
   IF MML$[J]=="{" THEN INC K
   IF MML$[J]=="}" AND K==0 THEN BREAK
   IF MML$[J]=="}" THEN DEC K
  NEXT
  K=INSTR(I,MML$,"=")
  IF K!=-1 AND K<J THEN I=K:CONTINUE
  N$=MID$(MML$,I+1,J-I-1)
  PUSH MT$,N$
  R$=EXMML$(MML$,N$)
  MML$=SUBST$(MML$,I,J-I+1,R$)
  I=I-1
 NEXT
 FOR I=0 TO LEN(MT$)-1
  MML$=EXMML_DEL$(MML$,MT$[I])
 NEXT
 RETURN MML$
END

DEF EXMML$(MML$,META$)
 VAR I,J,K=0,R$=""
 I=INSTR(MML$,"{"+META$+"=")
 IF I!=-1 THEN 
  I=I+LEN(META$)+2 '='のあとへ いどう
  FOR J=I TO LEN(MML$)-1
   IF MML$[J]=="{" THEN INC K
   IF MML$[J]=="}" AND K==0 THEN BREAK
   IF MML$[J]=="}" THEN DEC K
  NEXT
  R$=MID$(MML$,I,J-I)
 ENDIF
 '/n  CHR$(10)
 I=INSTR(R$,"/n")
 WHILE I>=0
  R$=SUBST$(R$,I,2,CHR$(10))
  I=INSTR(R$,"/n")
 WEND
 'n  CHR$(10)
 I=INSTR(R$,"n")
 WHILE I>=0
  R$=SUBST$(R$,I,2,CHR$(10))
  I=INSTR(R$,"n")
 WEND
 RETURN R$
END

DEF EXMML_DEL$(MML$,META$)
 VAR I,J,K,R$=MML$+""
 I=INSTR(MML$,"{"+META$+"=")
 IF I!=-1 THEN 
  FOR J=I+LEN(META$)+2 TO LEN(MML$)-1
   IF MML$[J]=="{" THEN INC K
   IF MML$[J]=="}" AND K==0 THEN BREAK
   IF MML$[J]=="}" THEN DEC K
  NEXT
  R$=SUBST$(MML$,I,J+1-I,"")
 ENDIF
 RETURN R$
END

